xt_checkout":"Checkout","text_recommendation_personalization_cart_free_shipping_message_01":"Spend another {additional} for free delivery.","text_cart_content_total":"Total","text_delete":"Remove","text_cart_free_shipping":"Eligible for free shipping.","text_gift_option":"Gift option","text_apply_coupon":"Apply voucher","text_gift_box_materials":"Gift wrapping materials will be included in the package along with the products","text_gift_option_delivery_effect":"If you apply a gift option, the delivery schedule may change.","text_gift_wrapping":"All items are gift wrapped","text_gift_wrapping_unavailable":"Gift wrapping is not available because your order has a large item.","text_store_inventory_purchase_add_to_cart_alteration_message":"Alteration is not available.","text_store_inventory_purchase_add_to_cart_complete_item_summary":"Subtotal: {item_quantity} item(s)","text_store_inventory_purchase_add_to_cart_complete_message_01":"Product availability is not yet guaranteed and will be confirmed once you complete the order.","text_store_inventory_purchase_add_to_cart_complete_message_02":"Novelty and gift options are not available with ORDER & PICK.","text_store_inventory_purchase_add_to_cart_complete_receive_store":"Receive store: {store_name}","text_store_inventory_purchase_add_to_cart_complete_title":"Added to cart","text_store_inventory_purchase_add_to_cart_submit_button":"Add to cart","text_store_inventory_purchase_add_to_cart_title":"Receive at {store_name}","text_store_inventory_purchase_switch_cart_change_button":"Change the store","text_store_inventory_purchase_switch_cart_check_button":"Check the cart","text_store_inventory_purchase_switch_cart_message_02":"If you change the store, the item will be deleted.","text_store_inventory_purchase_switch_cart_title":"Change receiving store","text_view_cart":"View cart","text_view_multibuy_item":"View multi-buy items","text_logout_confirmation":"Are you sure you want to log out?","text_multibuy_not_applied":"Multibuy not applied","text_employee_discount_amount_total":"Employee discount","text_item_total":"Item(s) subtotal","text_recommendation_personalization_cart_purchase_again":"Shop again","text_recommendation_personalization_cart_purchase_together":"Frequently bought together","text_recommendation_personalization_cart_ranking":"Trending best sellers","text_recommendation_personalization_cart_wishlist":"Items on Your Wishlist","text_cart_shipping_cost":"For FREE SHIPPING purchase for additional {additional} or opt for CLICK & COLLECT service & pick up your order from nearest UNIQLO Store.","text_add_gift_option":"Gift option","text_multibuy_applied":"Multi-buy applied","text_coupon_about_title":"About coupon","text_gift_option_imark_description01":"You can choose to wrap the items and deliver directly to your loved ones. Each order will be in 1 package (1 message card,1 gift bag). If the products, such as outerwear, do not fit into the wrapping material, it will be separately packed in Uniqlo Wrapping paper and will still be added in the package.","text_store_inventory_purchase_not_available_on_pc_message_01":"ORDER & PICK is only available on UNIQLO website or UNIQLO app.","text_store_inventory_purchase_not_available_on_pc_message_02":"Please use our mobile site or the UNIQLO app to choose ORDER & PICK.","text_add_available_item_to_cart_message":"text_add_available_item_to_cart_message","text_alteration_applied":"Note: You have opted length alteration for this item.","text_alteration_note":"Altered item cannot be returned/ exchanged.","text_cart_meta_description":"This is UNIQLO cart page.","text_cart_outofstock":"This item is currently out of stock. Please remove this item from your cart.","text_chat_support":"Chat support","text_chat_support_notes01":"Operator will answer your query.","text_chat_support_open_hour":"9:00 - 20:00(open all year round)","text_error_blacklist_account":"You cannot order on online store due to your account issue.","text_error_booking_inconsistency